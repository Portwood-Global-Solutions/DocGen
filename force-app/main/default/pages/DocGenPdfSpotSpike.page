<apex:page
    controller="DocGenPdfSpotSpikeController"
    showHeader="false"
    sidebar="false"
    standardStylesheets="false"
    applyHtmlTag="false"
    applyBodyTag="false"
>
    <!--
  SPIKE / throwaway — de-risk for guided PDF signing (Milestone 3).
  Proves: load PDF.js from a static resource, render an engine-produced PDF with a
  text layer, locate sign-spot anchor strings (even when split across text runs),
  and overlay a correctly-positioned interactive chip on each.
  NOT for release. Delete with DocGenPdfSpotSpikeController once M3 lands.
-->
    <html lang="en">
        <head>
            <meta charset="UTF-8" />
            <title>Guided Signing — Sign-Spot Spike</title>
            <apex:includeScript value="{!URLFOR($Resource.pdfjs, 'pdf.min.js')}" />
            <style>
                body {
                    font-family: Helvetica, Arial, sans-serif;
                    margin: 0;
                    background: #f4f6f9;
                    color: #161616;
                }
                #bar {
                    background: #032d60;
                    color: #fff;
                    padding: 10px 16px;
                    font-size: 14px;
                }
                #bar b {
                    color: #9bd0ff;
                }
                #log {
                    background: #fff;
                    border-bottom: 1px solid #ddd;
                    padding: 8px 16px;
                    font:
                        12px/1.5 Menlo,
                        monospace;
                    white-space: pre-wrap;
                }
                #pages {
                    padding: 20px;
                }
                .page-wrap {
                    position: relative;
                    margin: 0 auto 20px;
                    box-shadow: 0 1px 6px rgba(0, 0, 0, 0.2);
                    background: #fff;
                }
                .page-wrap canvas {
                    display: block;
                }
                /* Overlay chip drawn on top of a located anchor. */
                .spot-chip {
                    position: absolute;
                    background: rgba(255, 248, 197, 0.55);
                    border: 2px solid #f59e0b;
                    border-radius: 3px;
                    box-sizing: border-box;
                    cursor: pointer;
                    display: flex;
                    align-items: center;
                    justify-content: center;
                    font-size: 10px;
                    font-weight: bold;
                    color: #92400e;
                    overflow: visible;
                }
                .spot-chip .tab {
                    position: absolute;
                    left: -4px;
                    top: -18px;
                    background: #f59e0b;
                    color: #fff;
                    padding: 1px 6px;
                    border-radius: 3px;
                    white-space: nowrap;
                    font-size: 10px;
                }
                .spot-chip.current {
                    border-color: #0176d3;
                    background: rgba(1, 118, 211, 0.18);
                }
                .spot-chip.current .tab {
                    background: #0176d3;
                }
            </style>
        </head>
        <body>
            <div id="bar">
                Sign-Spot Spike — <span id="status">loading PDF.js…</span> &nbsp;|&nbsp; found
                <b id="count">0</b> anchors
            </div>
            <div id="log"></div>
            <div id="pages"></div>

            <script>
                var WORKER_SRC = "{!URLFOR($Resource.pdfjs, 'pdf.worker.min.js')}";

                function log(m) {
                    var el = document.getElementById('log');
                    el.textContent += m + '\n';
                }
                function setStatus(m) {
                    document.getElementById('status').textContent = m;
                }

                // --- Find a needle inside a page's text items, tolerating splits across runs ---
                // Concatenate all item strings, remember each item's [start,end) char range,
                // locate the needle in the concatenation, then union the device-space bounding
                // boxes of every item the match overlaps.
                function locateAnchors(textContent, viewport, needles) {
                    var combined = '';
                    var ranges = []; // { item, start, end }
                    for (var i = 0; i < textContent.items.length; i++) {
                        var it = textContent.items[i];
                        var s = combined.length;
                        combined += it.str;
                        ranges.push({ item: it, start: s, end: combined.length });
                    }
                    var hits = [];
                    for (var n = 0; n < needles.length; n++) {
                        var needle = needles[n];
                        var at = combined.indexOf(needle);
                        if (at < 0) continue;
                        var matchEnd = at + needle.length;
                        var box = null;
                        for (var r = 0; r < ranges.length; r++) {
                            var rg = ranges[r];
                            if (rg.end <= at || rg.start >= matchEnd) continue; // no overlap
                            var b = itemDeviceBox(rg.item, viewport);
                            box = box ? unionBox(box, b) : b;
                        }
                        if (box) hits.push({ needle: needle, box: box, split: true });
                    }
                    return hits;
                }

                // Convert a PDF.js text item to a device-space (top-left origin) bounding box.
                function itemDeviceBox(item, viewport) {
                    // item.transform = [a,b,c,d,e,f]; compose with viewport transform.
                    var tx = pdfjsLib.Util.transform(viewport.transform, item.transform);
                    // After composing, tx[4],tx[5] is the device position of the text baseline
                    // origin (bottom-left of the glyph box). Font height ~ sqrt(c^2+d^2).
                    var fontHeight = Math.hypot(item.transform[2], item.transform[3]) * viewport.scale;
                    var width = item.width * viewport.scale;
                    var x = tx[4];
                    var yBaseline = tx[5];
                    return { x: x, y: yBaseline - fontHeight, w: width, h: fontHeight };
                }
                function unionBox(a, b) {
                    var x1 = Math.min(a.x, b.x),
                        y1 = Math.min(a.y, b.y);
                    var x2 = Math.max(a.x + a.w, b.x + b.w),
                        y2 = Math.max(a.y + a.h, b.y + b.h);
                    return { x: x1, y: y1, w: x2 - x1, h: y2 - y1 };
                }

                function labelFor(needle) {
                    if (/Initials/i.test(needle)) return 'INITIAL HERE';
                    if (/:Date|DatePick/i.test(needle)) return 'DATE';
                    return 'SIGN HERE';
                }

                var allChips = [];

                function renderPage(pdf, pageNum, needles, scale) {
                    return pdf.getPage(pageNum).then(function (page) {
                        var viewport = page.getViewport({ scale: scale });
                        var wrap = document.createElement('div');
                        wrap.className = 'page-wrap';
                        wrap.style.width = viewport.width + 'px';
                        wrap.style.height = viewport.height + 'px';
                        var canvas = document.createElement('canvas');
                        canvas.width = viewport.width;
                        canvas.height = viewport.height;
                        wrap.appendChild(canvas);
                        document.getElementById('pages').appendChild(wrap);

                        return page
                            .render({ canvasContext: canvas.getContext('2d'), viewport: viewport })
                            .promise.then(function () {
                                return page.getTextContent();
                            })
                            .then(function (tc) {
                                var hits = locateAnchors(tc, viewport, needles);
                                log(
                                    'Page ' +
                                        pageNum +
                                        ': ' +
                                        tc.items.length +
                                        ' text items, ' +
                                        hits.length +
                                        ' anchor(s) located.'
                                );
                                for (var h = 0; h < hits.length; h++) {
                                    var hit = hits[h];
                                    var chip = document.createElement('div');
                                    chip.className = 'spot-chip';
                                    chip.style.left = hit.box.x + 'px';
                                    chip.style.top = hit.box.y + 'px';
                                    chip.style.width = Math.max(hit.box.w, 40) + 'px';
                                    chip.style.height = Math.max(hit.box.h, 18) + 'px';
                                    var tab = document.createElement('span');
                                    tab.className = 'tab';
                                    tab.textContent = labelFor(hit.needle) + ' — ' + hit.needle;
                                    chip.appendChild(tab);
                                    wrap.appendChild(chip);
                                    allChips.push(chip);
                                    log(
                                        '   ✓ "' +
                                            hit.needle +
                                            '" @ page ' +
                                            pageNum +
                                            ' box[x=' +
                                            Math.round(hit.box.x) +
                                            ' y=' +
                                            Math.round(hit.box.y) +
                                            ' w=' +
                                            Math.round(hit.box.w) +
                                            ' h=' +
                                            Math.round(hit.box.h) +
                                            ']'
                                    );
                                }
                                return hits.length;
                            });
                    });
                }

                function startWalkthrough() {
                    if (!allChips.length) return;
                    var idx = 0;
                    function focus(i) {
                        for (var c = 0; c < allChips.length; c++) allChips[c].classList.remove('current');
                        var chip = allChips[i];
                        chip.classList.add('current');
                        chip.scrollIntoView({ behavior: 'smooth', block: 'center' });
                        setStatus(
                            'Walkthrough: field ' + (i + 1) + ' of ' + allChips.length + ' (click a chip to advance)'
                        );
                    }
                    for (var c = 0; c < allChips.length; c++) {
                        (function (i) {
                            allChips[i].addEventListener('click', function () {
                                idx = (i + 1) % allChips.length;
                                focus(idx);
                            });
                        })(c);
                    }
                    focus(0);
                }

                function run() {
                    if (typeof pdfjsLib === 'undefined') {
                        setStatus('FAILED — pdfjsLib global not present');
                        log('ERROR: PDF.js did not load. Check static resource path.');
                        return;
                    }
                    pdfjsLib.GlobalWorkerOptions.workerSrc = WORKER_SRC;
                    log('PDF.js ' + pdfjsLib.version + ' loaded. worker=' + WORKER_SRC);
                    setStatus('generating test PDF…');

                    Visualforce.remoting.Manager.invokeAction(
                        '{!$RemoteAction.DocGenPdfSpotSpikeController.getAnchorsJson}',
                        function (anchorsJson, ev1) {
                            if (!ev1.status) {
                                log('getAnchorsJson failed: ' + ev1.message);
                                return;
                            }
                            var needles = JSON.parse(anchorsJson);
                            log('Searching for anchors: ' + needles.join(', '));
                            Visualforce.remoting.Manager.invokeAction(
                                '{!$RemoteAction.DocGenPdfSpotSpikeController.getTestPdfBase64}',
                                function (b64, ev2) {
                                    if (!ev2.status) {
                                        log('getTestPdfBase64 failed: ' + ev2.message);
                                        return;
                                    }
                                    setStatus('rendering…');
                                    var raw = atob(b64);
                                    var bytes = new Uint8Array(raw.length);
                                    for (var i = 0; i < raw.length; i++) bytes[i] = raw.charCodeAt(i);
                                    pdfjsLib.getDocument({ data: bytes }).promise.then(
                                        function (pdf) {
                                            log('PDF loaded: ' + pdf.numPages + ' page(s).');
                                            var chain = Promise.resolve(0);
                                            var total = 0;
                                            for (var p = 1; p <= pdf.numPages; p++) {
                                                (function (pageNum) {
                                                    chain = chain
                                                        .then(function () {
                                                            return renderPage(pdf, pageNum, needles, 1.3);
                                                        })
                                                        .then(function (found) {
                                                            total += found;
                                                        });
                                                })(p);
                                            }
                                            chain.then(function () {
                                                document.getElementById('count').textContent = total;
                                                setStatus(
                                                    total +
                                                        ' of ' +
                                                        needles.length +
                                                        ' anchors located — starting walkthrough'
                                                );
                                                startWalkthrough();
                                            });
                                        },
                                        function (err) {
                                            log('getDocument failed: ' + err);
                                            setStatus('FAILED rendering PDF');
                                        }
                                    );
                                },
                                { escape: false }
                            );
                        },
                        { escape: false }
                    );
                }

                if (document.readyState === 'complete') run();
                else window.addEventListener('load', run);
            </script>
        </body>
    </html>
</apex:page>
