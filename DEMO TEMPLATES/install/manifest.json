                        "parentNode": null,
                        "lookupField": null,
                        "relationshipName": null
                    },
                    {
                        "id": "n1",
                        "object": "Demo_Statement_Line__c",
                        "fields": [
                            "Transaction_Date__c",
                            "Description__c",
                            "Category__c",
                            "Amount__c",
                            "Running_Balance__c",
                            "Line_Order__c"
